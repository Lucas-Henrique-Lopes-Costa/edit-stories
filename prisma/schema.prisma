generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Video {
  id            String      @id @default(cuid())
  originalName  String
  fileName      String
  filePath      String
  status        String      @default("PENDING")
  shortName     String?
  shortNameAuto String?
  duration      Float?
  errorMessage      String?
  subtitlePosition  Float   @default(0.75)   // vertical center ratio 0=top 1=bottom
  fontSize          Float   @default(0.01875) // font size as fraction of video height
  trimStart         Float   @default(0)       // trim start in seconds
  trimEnd           Float?                    // trim end in seconds (null = full duration)
  withSubtitles     Boolean @default(true)    // whether to burn subtitles on export
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transcription Transcription?
  segments      Segment[]
  exportJobs    ExportJob[]
  products      VideoProduct[]
  metrics       VideoMetrics?
  scripts       Script[]
}

model VideoMetrics {
  id            String   @id @default(cuid())
  videoId       String   @unique
  video         Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  investedValue Float?   // Valor investido (R$)
  salesValue    Float?   // Valor de vendas (R$)
  salesCount    Int?     // Número de vendas
  impressions   Int?     // Impressões
  reach         Int?     // Alcance
  updatedAt     DateTime @updatedAt
}

model Product {
  id              String         @id @default(cuid())
  name            String         @unique
  description     String?
  benefits        String?
  targetAudience  String?
  price           String?
  objections      String?
  createdAt       DateTime       @default(now())
  videos          VideoProduct[]
  scripts         Script[]
}

model Company {
  id          String   @id @default(cuid())
  name        String   @default("")
  description String?
  tone        String?
  updatedAt   DateTime @updatedAt
}

model Script {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  videoId   String?
  video     Video?   @relation(fields: [videoId], references: [id], onDelete: SetNull)
  prompt    String
  content   String
  format    String?
  status    String   @default("TO_RECORD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoProduct {
  videoId   String
  productId String
  video     Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([videoId, productId])
}

model Transcription {
  id        String   @id @default(cuid())
  videoId   String   @unique
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  rawText   String
  language  String?
  createdAt DateTime @default(now())
}

model Segment {
  id           String   @id @default(cuid())
  videoId      String
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  index        Int
  startTime    Float
  endTime      Float
  originalText String
  editedText   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([videoId, index])
}

model ExportJob {
  id         String   @id @default(cuid())
  videoId    String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  status     String   @default("PENDING")
  outputPath String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
